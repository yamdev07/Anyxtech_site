# === Variables d'environnement AnyxTech ===
# Copiez ce fichier en ".env" et renseignez les valeurs.

# Secret utilisé par Payload pour signer les tokens d'authentification.
# Générez-en un : openssl rand -hex 32   (ou: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PAYLOAD_SECRET=remplacez-par-un-secret-aleatoire

# Base de données.
#  - Développement (par défaut) : SQLite local
#      DATABASE_URI=file:./payload.db
#  - Production (recommandé, ex. Neon/Supabase Postgres) : voir le README
#      DATABASE_URI=postgres://user:password@host:5432/dbname
DATABASE_URI=file:./payload.db
